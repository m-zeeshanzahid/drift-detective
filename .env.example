# ============================================================================
# Drift Detective — configuration template
# Copy to `.env` (git-ignored) and fill in YOUR values. Nothing here is shared.
# ============================================================================

# ── AWS (used by Terraform + AWS CLI to deploy, and by local Lambda testing) ──
# Credentials of an IAM user/role with enough rights to create the stack
# (S3, IAM roles/users, Lambda, EC2). Easiest: an admin user, then `aws configure`.
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── Terraform variables (optional overrides; Terraform reads TF_VAR_* env vars) ──
# Project name prefix for all resources.
TF_VAR_project=drift-detective
# S3 key of the Terraform state file the detector evaluates infra against.
# Upload your real terraform.tfstate to the state bucket under this key
# (or override per-run via the detector node's event: state_bucket / state_key).
TF_VAR_state_key=terraform.tfstate

# ── Bedrock (Claude Haiku 4.5) ──
# The deployed Lambdas authenticate to Bedrock via their IAM role — no key needed
# in production. The bearer token below is ONLY for local handler testing.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_REGION=us-east-1
# Optional, local testing only (put the real value in .env, never in .env.example):
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# ── SuperPlane (orchestration; used by the Render dashboard + worker) ──
SUPERPLANE_API_URL=https://api.superplane.com
SUPERPLANE_API_KEY=your_superplane_service_account_token
SUPERPLANE_ORG=your-org-slug
SUPERPLANE_APP_NAME=drift-detective

# ── Render services runtime ──
PORT=3000                 # dashboard web service
POLL_INTERVAL_SECONDS=300 # background worker scan cadence
