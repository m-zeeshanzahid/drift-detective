SUPERPLANE_API_URL=https://api.superplane.com
SUPERPLANE_API_KEY=sp_your_key_here
SUPERPLANE_ORG=your-org-slug
SUPERPLANE_APP_NAME=drift-detective

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Bedrock API key (bearer token) — optional, for local testing of the classifier only.
# The deployed Lambda authenticates to Bedrock via its IAM role, so this is NOT
# required in production. Put the real value in .env (gitignored), never here.
BEDROCK_API_KEY=your_bedrock_api_key_here
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

POLL_INTERVAL_SECONDS=300
PORT=3000
